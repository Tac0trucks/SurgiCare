<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="#FFFFFF"
    android:padding="24dp">

    <!-- Top App Icon Container -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_marginBottom="24dp"
        app:cardBackgroundColor="#CBFBF1"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:strokeWidth="0dp">

        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="center"
            android:src="@drawable/nursicare"
            app:tint="#009689"
            android:contentDescription="SurgiCare Logo" />
    </com.google.android.material.card.MaterialCardView>

    <!-- Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="SurgiCare"
        android:textSize="30sp"
        android:textColor="#1D293D"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <!-- Subtitle -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Your companion for post-surgery recovery"
        android:textSize="16sp"
        android:textColor="#62748E"
        android:layout_marginBottom="40dp"
        android:gravity="center" />

    <!-- Main Actions Container -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginHorizontal="8dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPatientRegister"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginBottom="16dp"
            android:text="Create Account"
            android:textSize="16sp"
            app:cornerRadius="12dp"
            app:backgroundTint="#009689" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPatientLogin"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="Log In"
            android:textSize="16sp"
            app:cornerRadius="12dp"
            app:strokeColor="#009689"
            android:textColor="#009689" />

    </LinearLayout>
</LinearLayout>