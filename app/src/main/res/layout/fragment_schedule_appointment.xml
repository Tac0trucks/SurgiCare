<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <!-- Top Navigation Bar -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:paddingHorizontal="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:text="Schedule Appointment"
            android:textColor="#1D293D"
            android:textSize="20sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <!-- Header Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E2E8F0" />

    <!-- Scrollable Content Area -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="24dp"
            android:paddingBottom="24dp">

            <!-- CONSULTATION TYPE -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CONSULTATION TYPE"
                android:textColor="#64748B"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.05"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:baselineAligned="false"
                android:layout_marginBottom="24dp">

                <!-- Teleconsult Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardTeleconsult"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="96dp"
                    android:layout_marginEnd="8dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardBackgroundColor="@color/bg_consultation_card"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/stroke_consultation_card"
                    app:strokeWidth="1.5dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="8dp">

                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:src="@drawable/ic_launcher_foreground"
                            app:tint="@color/content_consultation_card"
                            android:layout_marginBottom="8dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Teleconsult"
                            android:textColor="@color/content_consultation_card"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Clinic Visit Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardClinic"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="96dp"
                    android:layout_marginStart="8dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardBackgroundColor="@color/bg_consultation_card"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/stroke_consultation_card"
                    app:strokeWidth="1.5dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="8dp">

                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:src="@drawable/ic_launcher_foreground"
                            app:tint="@color/content_consultation_card"
                            android:layout_marginBottom="8dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Clinic Visit"
                            android:textColor="@color/content_consultation_card"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- SELECT DATE -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SELECT DATE"
                android:textColor="#64748B"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.05"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <!-- Today -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnDateToday"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="48dp"
                    android:layout_marginEnd="6dp"
                    android:text="Today"
                    android:textAllCaps="false"
                    android:textColor="@color/text_pill_solid_button"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    app:cornerRadius="12dp"
                    app:backgroundTint="@color/bg_pill_solid_button"
                    app:strokeColor="@color/stroke_pill_solid_button"
                    app:strokeWidth="1dp" />

                <!-- Tomorrow -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnDateTomorrow"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="48dp"
                    android:layout_marginHorizontal="6dp"
                    android:text="Tomorrow"
                    android:textAllCaps="false"
                    android:textColor="@color/text_pill_solid_button"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    app:cornerRadius="12dp"
                    app:backgroundTint="@color/bg_pill_solid_button"
                    app:strokeColor="@color/stroke_pill_solid_button"
                    app:strokeWidth="1dp" />

                <!-- Other -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnDateOther"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="48dp"
                    android:layout_marginStart="6dp"
                    android:text="Other"
                    android:textAllCaps="false"
                    android:textColor="@color/text_pill_solid_button"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    app:cornerRadius="12dp"
                    app:backgroundTint="@color/bg_pill_solid_button"
                    app:strokeColor="@color/stroke_pill_solid_button"
                    app:strokeWidth="1dp" />
            </LinearLayout>

            <!-- Custom Date Field (Visible because 'Other' is selected) -->
            <LinearLayout
                android:id="@+id/containerCustomDate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Custom Date"
                    android:textColor="#64748B"
                    android:textSize="12sp"
                    android:layout_marginBottom="8dp" />

                <EditText
                    android:id="@+id/etCustomDate"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_outline_input"
                    android:paddingHorizontal="16dp"
                    android:hint=""
                    android:inputType="date"
                    android:textColor="#1E293B"
                    android:textSize="14sp"/>
            </LinearLayout>

            <!-- SELECT TIME -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SELECT TIME"
                android:textColor="#64748B"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.05"
                android:layout_marginBottom="12dp" />

            <!-- Time Grid (2x2) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Row 1 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnTime1"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="52dp"
                        android:layout_marginEnd="6dp"
                        android:text="09:00 AM"
                        android:textAllCaps="false"
                        android:textColor="@color/content_consultation_card"
                        android:textSize="14sp"
                        app:cornerRadius="12dp"
                        app:backgroundTint="@color/bg_consultation_card"
                        app:strokeColor="@color/stroke_consultation_card"
                        app:strokeWidth="1.5dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnTime2"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="52dp"
                        android:layout_marginStart="6dp"
                        android:text="10:30 AM"
                        android:textAllCaps="false"
                        android:textColor="@color/content_consultation_card"
                        android:textSize="14sp"
                        app:cornerRadius="12dp"
                        app:backgroundTint="@color/bg_consultation_card"
                        app:strokeColor="@color/stroke_consultation_card"
                        app:strokeWidth="1.5dp" />
                </LinearLayout>

                <!-- Row 2 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- 01:00 PM -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnTime3"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="52dp"
                        android:layout_marginEnd="6dp"
                        android:text="01:00 PM"
                        android:textAllCaps="false"
                        android:textColor="@color/content_consultation_card"
                        android:textSize="14sp"
                        app:cornerRadius="12dp"
                        app:backgroundTint="@color/bg_consultation_card"
                        app:strokeColor="@color/stroke_consultation_card"
                        app:strokeWidth="1.5dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnTime4"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="52dp"
                        android:layout_marginStart="6dp"
                        android:text="03:30 PM"
                        android:textAllCaps="false"
                        android:textColor="@color/content_consultation_card"
                        android:textSize="14sp"
                        app:cornerRadius="12dp"
                        app:backgroundTint="@color/bg_consultation_card"
                        app:strokeColor="@color/stroke_consultation_card"
                        app:strokeWidth="1.5dp" />
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Bottom Button Container pinned to the bottom -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="16dp"
        android:paddingBottom="32dp"
        android:background="#FFFFFF">

        <!-- Enabled Confirm Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnConfirm"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Confirm Appointment"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            app:cornerRadius="12dp"
            app:backgroundTint="#009689"
            android:enabled="true" />

    </LinearLayout>

</LinearLayout>